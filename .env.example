# Copy to .env and fill in the real values before running docker compose up.

# MQTT broker — localhost works because this container uses network_mode: host.
MQTT_HOST=localhost
MQTT_PORT=1883

# MQTT credentials for the mt3 server identity.
# Generate with:  docker compose -f ../compose.yaml exec auth python manage.py add-agent mt3
MT3_MQTT_USERNAME=mt3
MT3_MQTT_PASSWORD=change-me

# Optional: set to DEBUG for verbose output.
LUCID_LOG_LEVEL=INFO
